rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Word bank: Every player needs to read it to fetch/validate words; the app
    // itself never writes to it.
    match /words/{wordId} {
      allow read: if true;
      allow write: if false;
    }

    // One puzzle config per calendar date (doc id like "2026-07-17"). Whoever
    // is the first player to load that day generates it; once it exists it's
    // locked, so nobody can tamper with a day's answers after the fact.
    match /dailies/{dateId} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/dailies/$(dateId));
      allow update: if false;
      // The app only ever deletes ~30-day-old entries for cleanup;
      allow delete: if true;
    }

    // Win/loss stats recorded at the end of every game (see stats.js), read back
    // by GameInfoView's tallies. Anonymous, append-only — no update or delete.
    match /gameResults/{resultId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Dev-only sticky notes on GameInfoView (game notes, "needed from X", and
    // feature suggestions). Wide open on purpose: it's just a scratch board for
    // a couple of people, doesn't affect the game, and will be removed before
    // this project is more widely known.
    match /notes/{noteId} {
      allow read, write: if true;
    }

    // Deny everything else — including the unused `game/counter` doc — by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
